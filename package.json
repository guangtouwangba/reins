{
  "name": "reins",
  "version": "0.1.0",
  "type": "module",
  "description": "AI coding agent constraint governance tool",
  "bin": {
    "reins": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "glob": "^11.0.2",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.2.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "tree-sitter-javascript",
      "tree-sitter-python",
      "tree-sitter-typescript",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
